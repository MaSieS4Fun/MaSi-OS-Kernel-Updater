 *
 * AYANEO Pocket S 2K (slot 13) — dual-DSI wt0600-2k panel, gt911 touch.
 * Derived from ARMADA slot-13 reference + ayaneo pocket common.
 */

/dts-v1/;

#include "qcs8550-ayaneo-pocket-common.dtsi"

/ {
	model = "AYANEO Pocket S 2K";
	qcom,board-id = <0x1000b 0x01>;
	qcom,msm-id = <0x258 0x20000>, <0x259 0x20000>;
	compatible = "ayaneo,pocket-s1", "qcom,qcs8550", "qcom,sm8550";
	rocknix-u-boot-dt-id = "u-boot-pocket-s1";
};

&tlmm {
	panel_pwr_active: panel-pwr-active-state {
		pins = "gpio152", "gpio153";
		function = "gpio";
		drive-strength = <8>;
		bias-disable;
		output-high;
	};

	panel_pwr_sleep: panel-pwr-sleep-state {
		pins = "gpio152", "gpio153";
		function = "gpio";
		output-low;
	};

	backlight_pwr_active: backlight-pwr-active-state {
		pins = "gpio41";
		function = "gpio";
		drive-strength = <8>;
		bias-disable;
		output-high;
	};

	backlight_pwr_sleep: backlight-pwr-sleep-state {
		pins = "gpio41";
		function = "gpio";
		output-low;
	};

	ts_int_active: ts-int-active-state {
		pins = "gpio25";
		function = "gpio";
		drive-strength = <8>;
		bias-pull-up;
	};

	ts_reset_active: ts-reset-active-state {
		pins = "gpio24";
		function = "gpio";
		drive-strength = <8>;
		bias-pull-up;
	};

	ts_int_suspend: ts-int-suspend-state {
		pins = "gpio25";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-down;
	};

	ts_reset_suspend: ts-reset-suspend-state {
		pins = "gpio24";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-down;
	};
};

&i2c0 {
	clock-frequency = <400000>;
	status = "okay";

	sgm3804: regulator@3e {
		compatible = "sgmicro,sgm3804";
		reg = <0x3e>;
		pinctrl-0 = <&panel_pwr_active>;
		pinctrl-1 = <&panel_pwr_sleep>;
		pinctrl-names = "default", "sleep";
		regulator-name = "panel-avdd";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		reset-gpios = <&tlmm 152 GPIO_ACTIVE_HIGH>, <&tlmm 153 GPIO_ACTIVE_HIGH>;
	};

	backlight: sy7758@2e {
		compatible = "silergy,sy7758";
		reg = <0x2e>;
		pinctrl-0 = <&backlight_pwr_active>;
		pinctrl-1 = <&backlight_pwr_sleep>;
		pinctrl-names = "default", "sleep";
		status = "okay";
	};
};

&i2c4 {
	clock-frequency = <400000>;
	status = "okay";

	touchscreen@5d {
		compatible = "goodix,gt911";
		reg = <0x5d>;

		interrupt-parent = <&tlmm>;
		interrupts = <25 IRQ_TYPE_EDGE_FALLING>;

		reset-gpios = <&tlmm 24 GPIO_ACTIVE_LOW>;

		VDDIO-supply = <&vreg_l14b_3p2>;
		AVDD28-supply = <&vreg_l14b_3p2>;

		touchscreen-size-x = <1440>;
		touchscreen-size-y = <2560>;

		pinctrl-names = "default", "sleep";
		pinctrl-0 = <&ts_int_active &ts_reset_active>;
		pinctrl-1 = <&ts_int_suspend &ts_reset_suspend>;
	};
};

&mdss_dsi0 {
	qcom,master-dsi;
	qcom,dual-dsi-mode;
	qcom,sync-dual-dsi;
};

&mdss_dsi1 {
	vdda-supply = <&vreg_l3e_1p2>;
	status = "okay";
};

&mdss_dsi1_phy {
	vdds-supply = <&vreg_l1e_0p88>;
	status = "okay";
};

&display_panel {
	compatible = "ayaneo,wt0600-2k", "renesas,r63419";

	vdd-supply = <&vreg_l14b_3p2>;
	vddio-supply = <&vreg_l12b_1p8>;
	vci-supply = <&vreg_l13b_3p0>;
	vsp-supply = <&sgm3804>;
	vsn-supply = <&sgm3804>;

	reset-gpios = <&tlmm 133 GPIO_ACTIVE_LOW>;
	backlight = <&backlight>;
	rotation = <90>;

	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@1 {
			reg = <1>;

			panel1_in: endpoint {
				remote-endpoint = <&mdss_dsi1_out>;
			};
		};
	};
};

&mdss_dsi1_out {
	remote-endpoint = <&panel1_in>;
	data-lanes = <0 1 2 3>;
};
