diff -Naur a/drivers/gpu/drm/panel/panel-ddic-ch13726a.c b/drivers/gpu/drm/panel/panel-ddic-ch13726a.c
--- a/drivers/gpu/drm/panel/panel-ddic-ch13726a.c
+++ b/drivers/gpu/drm/panel/panel-ddic-ch13726a.c
@@ -35,11 +35,11 @@ static inline struct ch13726a_panel *to_ch13726a_panel(struct drm_panel *panel)
 
 static void ch13726a_reset(struct ch13726a_panel *ctx)
 {
-	gpiod_set_value_cansleep(ctx->reset_gpio, 1);
+	gpiod_set_value_cansleep(ctx->reset_gpio, 0);
 	usleep_range(10000, 11000);
-	gpiod_set_value_cansleep(ctx->reset_gpio, 0);
+	gpiod_set_value_cansleep(ctx->reset_gpio, 1);
 	usleep_range(10000, 11000);
-	gpiod_set_value_cansleep(ctx->reset_gpio, 1);
+	gpiod_set_value_cansleep(ctx->reset_gpio, 0);
 	usleep_range(10000, 11000);
 }
 
@@ -94,7 +94,7 @@ static int ch13726a_prepare(struct drm_panel *panel)
 	ret = ch13726a_on(ctx);
 	if (ret < 0) {
 		dev_err(dev, "Failed to initialize panel: %d\n", ret);
