 		return 0;
 
 	if (tsdata->suspend_mode == EDT_PMODE_NOT_SUPPORTED)
@@ -1453,7 +1458,7 @@ static int edt_ft5x06_ts_resume(struct device *dev)
 	struct edt_ft5x06_ts_data *tsdata = i2c_get_clientdata(client);
 	int ret = 0;
 
-	if (device_may_wakeup(dev))
+	if (device_may_wakeup(dev) || tsdata->retain_power_in_suspend)
 		return 0;
 
