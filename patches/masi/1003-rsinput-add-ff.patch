diff --git a/drivers/input/joystick/rsinput.c b/drivers/input/joystick/rsinput.c
index 111111111111..222222222222 100644
--- a/drivers/input/joystick/rsinput.c
+++ b/drivers/input/joystick/rsinput.c
@@ -60,6 +60,9 @@ struct rsinput_driver {
     uint8_t sequence_number;
 };
 
+static bool rumble_enable = true;
+module_param(rumble_enable, bool, 0644);
+MODULE_PARM_DESC(rumble_enable, "Enable gamepad rumble via PMIC haptics");
+
 static const unsigned int keymap[] = {
     BTN_DPAD_UP, BTN_DPAD_DOWN, BTN_DPAD_LEFT, BTN_DPAD_RIGHT,
     BTN_NORTH,   BTN_WEST,	    BTN_EAST,	   BTN_SOUTH,
@@ -329,6 +332,22 @@ static const struct serdev_device_ops rsinput_rx_ops = {
     .receive_buf = rsinput_rx,
 };
 
+extern int qcom_spmi_haptics_global_upload(struct ff_effect *effect);
+extern int qcom_spmi_haptics_global_playback(int effect_id, int val);
+
+static int rsinput_rumble_upload(struct input_dev *dev, struct ff_effect *effect,
+				 struct ff_effect *old)
+{
+	if (!rumble_enable)
+		return 0;
+	return qcom_spmi_haptics_global_upload(effect);
+}
+
+static int rsinput_rumble_play(struct input_dev *dev, int effect_id, int val)
+{
+	if (!rumble_enable)
+		return 0;
+	return qcom_spmi_haptics_global_playback(effect_id, val);
+}
+
 static int rsinput_probe(struct serdev_device *serdev) {
     struct rsinput_driver *drv;
     u32 gamepad_bus = 0;
@@ -445,6 +464,16 @@ static int rsinput_probe(struct serdev_device *serdev) {
     input_set_abs_params(drv->input, ABS_Z, 0, 1830, 0, 30);
     input_set_abs_params(drv->input, ABS_RZ, 0, 1830, 0, 30);
 
+    input_set_capability(drv->input, EV_FF, FF_PERIODIC);
+
+    error = input_ff_create(drv->input, 1);
+    if (error) {
+        serdev_device_close(serdev);
+        return dev_err_probe(&serdev->dev, error, "Unable to create force feedback device\n");
+    }
+
+    drv->input->ff->upload = rsinput_rumble_upload;
+    drv->input->ff->playback = rsinput_rumble_play;
+
     error = input_register_device(drv->input);
     if (error) {
         serdev_device_close(serdev);
diff --git a/drivers/input/misc/qcom-hv-haptics.c b/drivers/input/misc/qcom-hv-haptics.c
index 333333333333..444444444444 100644
--- a/drivers/input/misc/qcom-hv-haptics.c
+++ b/drivers/input/misc/qcom-hv-haptics.c
@@ -31,6 +31,7 @@
 #include <linux/uaccess.h>
 #include <linux/workqueue.h>
 #include <linux/vmalloc.h>
+#include <linux/export.h>
 #include <linux/qpnp/qpnp-pbs.h>
 
 #include <linux/soc/qcom/battery_charger.h>
@@ -668,6 +669,8 @@ struct haptics_reg_info {
 	u8 val;
 };
 
+static struct haptics_chip *global_haptics;
+
 static inline int get_max_fifo_samples(struct haptics_chip *chip)
 {
 	int val = 0;
@@ -6067,6 +6070,8 @@ static int haptics_probe(struct platform_device *pdev)
 	if (rc < 0)
 		dev_err(chip->dev, "Creating debugfs failed, rc=%d\n", rc);
 #endif
+
+	global_haptics = chip;
 
 	return 0;
 destroy_ff:
@@ -6080,6 +6085,9 @@ static int haptics_remove(struct platform_device *pdev)
 	if (chip->pbs_node)
 		of_node_put(chip->pbs_node);
 
+	if (global_haptics == chip)
+		global_haptics = NULL;
+
 	unregister_hboost_event_notifier(&chip->hboost_nb);
 	class_unregister(&chip->hap_class);
 #ifdef CONFIG_DEBUG_FS
@@ -6277,5 +6285,58 @@ static struct platform_driver haptics_driver = {
 };
 module_platform_driver(haptics_driver);
 
+int qcom_spmi_haptics_global_upload(struct ff_effect *effect)
+{
+	int ret;
+
+	if (!global_haptics)
+		return -ENODEV;
+
+	spin_lock_irq(&global_haptics->input_dev->event_lock);
+	ret = global_haptics->input_dev->ff->upload(global_haptics->input_dev,
+						    effect, NULL);
+	spin_unlock_irq(&global_haptics->input_dev->event_lock);
+
+	return ret;
+}
+EXPORT_SYMBOL_GPL(qcom_spmi_haptics_global_upload);
+
+int qcom_spmi_haptics_global_playback(int effect_id, int val)
+{
+	int ret;
+
+	if (!global_haptics)
+		return -ENODEV;
+
+	spin_lock_irq(&global_haptics->input_dev->event_lock);
+	if (val != 0)
+		ret = global_haptics->input_dev->ff->playback(global_haptics->input_dev,
+							      effect_id, val);
+	else
+		ret = global_haptics->input_dev->ff->erase(global_haptics->input_dev,
+							   effect_id);
+	spin_unlock_irq(&global_haptics->input_dev->event_lock);
+
+	return ret;
+}
+EXPORT_SYMBOL_GPL(qcom_spmi_haptics_global_playback);
+
+int qcom_spmi_haptics_global_set_gain(u16 gain)
+{
+	if (!global_haptics)
+		return -ENODEV;
+
+	spin_lock_irq(&global_haptics->input_dev->event_lock);
+	gain = clamp(gain, 0x4000, 0x7fff);
+	global_haptics->input_dev->ff->set_gain(global_haptics->input_dev, gain);
+	spin_unlock_irq(&global_haptics->input_dev->event_lock);
+
+	return 0;
+}
+EXPORT_SYMBOL_GPL(qcom_spmi_haptics_global_set_gain);
+
 MODULE_DESCRIPTION("Qualcomm Technologies, Inc. High-Voltage Haptics driver");
 MODULE_LICENSE("GPL v2");
