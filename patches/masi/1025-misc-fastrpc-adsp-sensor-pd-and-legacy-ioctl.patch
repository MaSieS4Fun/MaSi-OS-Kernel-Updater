 #define USER_PD		(1)
 #define SENSORS_PD	(2)
 
+/* Context bank process types used by Qualcomm downstream DTs. */
+#define FASTRPC_PD_TYPE_UNSPECIFIED	(0)
+#define FASTRPC_PD_TYPE_ROOT		(1)
+#define FASTRPC_PD_TYPE_AUDIO		(2)
+#define FASTRPC_PD_TYPE_SENSORS		(3)
+#define FASTRPC_PD_TYPE_USER		(7)
+
+/*
+ * Qualcomm's downstream userspace ABI predates the upstream FastRPC UAPI.
+ * The ioctl numbers overlap, but their encoded sizes differ except for a
+ * few commands.  Once a file uses a downstream-only command, keep it in
+ * legacy mode so the overlapping invoke/map commands can be decoded
+ * unambiguously.
+ */
+#define FASTRPC_LEGACY_INIT_ATTACH		(0)
+#define FASTRPC_LEGACY_INIT_ATTACH_SENSORS	(3)
+
+struct fastrpc_legacy_remote_arg {
+	union {
+		struct {
+			u64 ptr;
+			u64 length;
+		} buf;
+		struct {
+			s32 fd;
+			u32 offset;
+			u32 length;
+			u32 reserved;
+		} dma;
+	};
+};
+
+struct fastrpc_legacy_invoke_fd {
+	struct fastrpc_invoke inv;
+	u64 fds;
+};
+
+struct fastrpc_legacy_invoke_attrs {
+	struct fastrpc_invoke inv;
+	u64 fds;
+	u64 attrs;
+};
+
+struct fastrpc_legacy_invoke_crc {
+	struct fastrpc_invoke inv;
+	u64 fds;
+	u64 attrs;
+	u64 crc;
+};
+
+struct fastrpc_legacy_init {
+	u32 flags;
+	u32 reserved;
+	u64 file;
+	u32 filelen;
+	s32 filefd;
+	u64 mem;
+	u32 memlen;
+	s32 memfd;
+};
+
+struct fastrpc_legacy_control {
+	u32 req;
+	u32 data[2];
+};
+
+struct fastrpc_legacy_session_info {
+	u32 domain;
+	u32 session;
+	u32 reserved;
+};
+
+struct fastrpc_legacy_capability {
+	u32 domain;
+	u32 attribute_id;
+	u32 capability;
+	u32 reserved[3];
+};
+
+#define FASTRPC_LEGACY_IOCTL_INVOKE \
+	_IOWR('R', 1, struct fastrpc_invoke)
+#define FASTRPC_LEGACY_IOCTL_MMAP \
+	_IOWR('R', 2, struct fastrpc_req_mmap)
+#define FASTRPC_LEGACY_IOCTL_MUNMAP \
+	_IOWR('R', 3, struct fastrpc_req_munmap)
+#define FASTRPC_LEGACY_IOCTL_INVOKE_FD \
+	_IOWR('R', 4, struct fastrpc_legacy_invoke_fd)
+#define FASTRPC_LEGACY_IOCTL_SETMODE \
+	_IOWR('R', 5, u32)
+#define FASTRPC_LEGACY_IOCTL_INIT \
+	_IOWR('R', 6, struct fastrpc_legacy_init)
+#define FASTRPC_LEGACY_IOCTL_INVOKE_ATTRS \
+	_IOWR('R', 7, struct fastrpc_legacy_invoke_attrs)
+#define FASTRPC_LEGACY_IOCTL_GETINFO \
+	_IOWR('R', 8, u32)
+#define FASTRPC_LEGACY_IOCTL_INVOKE_CRC \
+	_IOWR('R', 11, struct fastrpc_legacy_invoke_crc)
+#define FASTRPC_LEGACY_IOCTL_CONTROL \
+	_IOWR('R', 12, struct fastrpc_legacy_control)
+#define FASTRPC_LEGACY_IOCTL_MMAP_64 \
+	_IOWR('R', 14, struct fastrpc_req_mmap)
+#define FASTRPC_LEGACY_IOCTL_MUNMAP_64 \
+	_IOWR('R', 15, struct fastrpc_req_munmap)
+#define FASTRPC_LEGACY_IOCTL_SET_SESSION_INFO \
+	_IOWR('R', 17, struct fastrpc_legacy_session_info)
+#define FASTRPC_LEGACY_IOCTL_GET_DSP_INFO \
+	_IOWR('R', 18, struct fastrpc_legacy_capability)
+
 #define miscdev_to_fdevice(d) container_of(d, struct fastrpc_device, miscdev)
 
