-			src_perms |= BIT(fl->cctx->vmperms[i].vmid);
-
-		dst_perms.vmid = QCOM_SCM_VMID_HLOS;
-		dst_perms.perm = QCOM_SCM_PERM_RWX;
-		err = qcom_scm_assign_mem(fl->cctx->remote_heap->dma_addr,
-						(u64)fl->cctx->remote_heap->size,
-						&src_perms, &dst_perms, 1);
-		if (err)
-			dev_err(fl->sctx->dev, "Failed to assign memory dma_addr %pad size 0x%llx err %d\n",
-				&fl->cctx->remote_heap->dma_addr, fl->cctx->remote_heap->size, err);
+	if (fl->cctx->vmcount) {
+		int unassign_err;
+
+		unassign_err = fastrpc_remote_heap_unassign(fl->cctx,
+							   fl->sctx->dev);
+		if (unassign_err)
+			goto err_name;
 	}
 err_map:
 	fastrpc_buf_free(fl->cctx->remote_heap);
@@ -1572,8 +1711,7 @@
 	return err;
 }
 
-static struct fastrpc_session_ctx *fastrpc_session_alloc(
-					struct fastrpc_user *fl)
+static int fastrpc_session_select(struct fastrpc_user *fl, u32 pd_type)
 {
 	struct fastrpc_channel_ctx *cctx = fl->cctx;
 	struct fastrpc_session_ctx *session = NULL;
@@ -1581,18 +1719,62 @@
 	int i;
 
 	spin_lock_irqsave(&cctx->lock, flags);
-	for (i = 0; i < cctx->sesscount; i++) {
-		if (!cctx->session[i].used && cctx->session[i].valid) {
-			cctx->session[i].used = true;
-			session = &cctx->session[i];
-			/* any non-zero ID will work, session_idx + 1 is the simplest one */
-			fl->client_id = i + 1;
-			break;
+
+	if (fl->sctx &&
+	    (pd_type == FASTRPC_PD_TYPE_UNSPECIFIED ||
+	     fl->sctx->pd_type == pd_type))
+		goto out;
+
+	if (fl->sctx) {
+		fl->sctx->used = false;
+		fl->sctx = NULL;
+	}
+
+	if (pd_type != FASTRPC_PD_TYPE_UNSPECIFIED) {
+		for (i = 0; i < cctx->sesscount; i++) {
+			if (!cctx->session[i].used && cctx->session[i].valid &&
+			    cctx->session[i].pd_type == pd_type) {
+				session = &cctx->session[i];
+				break;
+			}
+		}
+	}
+
+	if (!session) {
+		for (i = 0; i < cctx->sesscount; i++) {
+			if (!cctx->session[i].used && cctx->session[i].valid &&
+			    cctx->session[i].pd_type == FASTRPC_PD_TYPE_UNSPECIFIED) {
+				session = &cctx->session[i];
+				break;
+			}
 		}
 	}
+
+	/*
+	 * Preserve the historical first-free behavior for DTs that only
+	 * describe some process types, or do not describe them at all.
+	 */
+	if (!session) {
+		for (i = 0; i < cctx->sesscount; i++) {
+			if (!cctx->session[i].used && cctx->session[i].valid) {
+				session = &cctx->session[i];
+				break;
+			}
+		}
+	}
+
+	if (session) {
+		session->used = true;
+		fl->sctx = session;
+		/* Any non-zero ID works; session index + 1 is the simplest. */
+		fl->client_id = session - cctx->session + 1;
+	}
+
+out:
+	session = fl->sctx;
 	spin_unlock_irqrestore(&cctx->lock, flags);
 
-	return session;
+	return session ? 0 : -EBUSY;
 }
 
 static void fastrpc_session_free(struct fastrpc_channel_ctx *cctx,
@@ -1600,11 +1782,122 @@
 {
 	unsigned long flags;
 
+	if (!session)
+		return;
+
 	spin_lock_irqsave(&cctx->lock, flags);
 	session->used = false;
 	spin_unlock_irqrestore(&cctx->lock, flags);
 }
 
+static int fastrpc_wait_for_sensor_pd(struct fastrpc_user *fl)
+{
+	struct fastrpc_channel_ctx *cctx = fl->cctx;
+	int err;
+
+	if (fl->pd != SENSORS_PD || !cctx->sensors_pdr)
+		return 0;
+
+	err = wait_event_interruptible(cctx->sensors_pd_waitq,
+				       atomic_read(&cctx->sensors_pd_up) ||
+				       !READ_ONCE(cctx->rpdev));
+	if (err)
+		return err;
+
+	return READ_ONCE(cctx->rpdev) ? 0 : -EPIPE;
+}
+
+static u32 fastrpc_ioctl_pd_type(unsigned int cmd)
+{
+	switch (cmd) {
+	case FASTRPC_IOCTL_INIT_ATTACH:
+		return FASTRPC_PD_TYPE_ROOT;
+	case FASTRPC_IOCTL_INIT_ATTACH_SNS:
+		return FASTRPC_PD_TYPE_SENSORS;
+	case FASTRPC_IOCTL_INIT_CREATE_STATIC:
+		return FASTRPC_PD_TYPE_AUDIO;
+	case FASTRPC_IOCTL_INIT_CREATE:
+		return FASTRPC_PD_TYPE_USER;
+	default:
+		return FASTRPC_PD_TYPE_UNSPECIFIED;
+	}
+}
+
+static bool fastrpc_ioctl_is_init(unsigned int cmd)
+{
+	return cmd == FASTRPC_IOCTL_INIT_ATTACH ||
+	       cmd == FASTRPC_IOCTL_INIT_ATTACH_SNS ||
+	       cmd == FASTRPC_IOCTL_INIT_CREATE_STATIC ||
+	       cmd == FASTRPC_IOCTL_INIT_CREATE;
+}
+
+static void fastrpc_sensor_pd_status(int state, char *service_path, void *priv)
+{
+	struct fastrpc_channel_ctx *cctx = priv;
+	struct fastrpc_user *user;
+	unsigned long flags;
+
+	switch (state) {
+	case SERVREG_SERVICE_STATE_UP:
+		atomic_set(&cctx->sensors_pd_up, 1);
+		wake_up_interruptible(&cctx->sensors_pd_waitq);
+		if (cctx->rpdev)
+			dev_info(&cctx->rpdev->dev, "%s is up\n",
+				 service_path);
+		break;
+	case SERVREG_SERVICE_STATE_DOWN:
+	case SERVREG_SERVICE_STATE_EARLY_DOWN:
+		atomic_set(&cctx->sensors_pd_up, 0);
+
+		spin_lock_irqsave(&cctx->lock, flags);
+		list_for_each_entry(user, &cctx->users, user) {
+			if (user->pd == SENSORS_PD)
+				fastrpc_notify_users(user);
+		}
+		spin_unlock_irqrestore(&cctx->lock, flags);
+
+		if (cctx->rpdev)
+			dev_info(&cctx->rpdev->dev, "%s is down\n",
+				 service_path);
+		break;
+	default:
+		break;
+	}
+}
+
+static int fastrpc_setup_sensor_pdr(struct fastrpc_channel_ctx *cctx,
+				    struct device *dev)
+{
+	struct pdr_service *service;
+	int err;
+
+	if (!of_property_read_bool(dev->of_node,
+				   "qcom,fastrpc-adsp-sensors-pdr"))
+		return 0;
+
+	cctx->sensors_pdr = pdr_handle_alloc(fastrpc_sensor_pd_status, cctx);
+	if (IS_ERR(cctx->sensors_pdr)) {
+		err = PTR_ERR(cctx->sensors_pdr);
+		cctx->sensors_pdr = NULL;
+		return dev_err_probe(dev, err,
+				     "failed to initialize sensors PDR\n");
+	}
+
+	service = pdr_add_lookup(cctx->sensors_pdr, "tms/servreg",
+				 "msm/adsp/sensor_pd");
+	if (IS_ERR(service)) {
+		err = PTR_ERR(service);
+		pdr_handle_release(cctx->sensors_pdr);
+		cctx->sensors_pdr = NULL;
+		return dev_err_probe(dev, err,
+				     "failed to add sensor_pd PDR lookup\n");
+	}
+
+	dev_info(dev, "tracking msm/adsp/sensor_pd with PDR\n");
+
+	return 0;
+}
