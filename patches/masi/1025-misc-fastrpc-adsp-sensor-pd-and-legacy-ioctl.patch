+static int fastrpc_remote_heap_unassign(struct fastrpc_channel_ctx *cctx,
+					struct device *dev)
+{
+	struct qcom_scm_vmperm dst_perms;
+	u64 src_perms = 0;
+	u32 i;
+	int err;
+
+	if (!cctx->remote_heap || !cctx->vmcount ||
+	    !cctx->remote_heap_assigned)
+		return 0;
+
+	for (i = 0; i < cctx->vmcount; i++)
+		src_perms |= BIT(cctx->vmperms[i].vmid);
+
+	dst_perms.vmid = QCOM_SCM_VMID_HLOS;
+	dst_perms.perm = QCOM_SCM_PERM_RWX;
+
+	err = qcom_scm_assign_mem(cctx->remote_heap->dma_addr,
+				  (u64)cctx->remote_heap->size,
+				  &src_perms, &dst_perms, 1);
+	if (err)
+		dev_err(dev,
+			"Failed to return remote heap dma_addr %pad size 0x%llx to HLOS: %d\n",
+			&cctx->remote_heap->dma_addr, cctx->remote_heap->size, err);
+	else
+		cctx->remote_heap_assigned = false;
+
+	return err;
+}
+
 static int fastrpc_init_create_static_process(struct fastrpc_user *fl,
 					      char __user *argp)
 {
