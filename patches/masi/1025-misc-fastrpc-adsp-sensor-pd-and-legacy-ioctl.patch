+static int fastrpc_legacy_invoke(struct fastrpc_user *fl,
+				 unsigned int cmd, char __user *argp)
+{
+	struct fastrpc_legacy_remote_arg *legacy_args = NULL;
+	struct fastrpc_invoke_args *args = NULL;
+	struct fastrpc_invoke inv;
+	u32 *attrs = NULL;
+	s32 *fds = NULL;
+	u64 attrs_ptr = 0;
+	u64 fds_ptr = 0;
+	u32 nbufs;
+	u32 nscalars;
+	int err = 0;
+	u32 i;
+
+	switch (cmd) {
+	case FASTRPC_LEGACY_IOCTL_INVOKE:
+		if (copy_from_user(&inv, argp, sizeof(inv)))
+			return -EFAULT;
+		break;
+	case FASTRPC_LEGACY_IOCTL_INVOKE_FD: {
+		struct fastrpc_legacy_invoke_fd invoke;
+
+		if (copy_from_user(&invoke, argp, sizeof(invoke)))
+			return -EFAULT;
+		inv = invoke.inv;
+		fds_ptr = invoke.fds;
+		break;
+	}
+	case FASTRPC_LEGACY_IOCTL_INVOKE_ATTRS: {
+		struct fastrpc_legacy_invoke_attrs invoke;
+
+		if (copy_from_user(&invoke, argp, sizeof(invoke)))
+			return -EFAULT;
+		inv = invoke.inv;
+		fds_ptr = invoke.fds;
+		attrs_ptr = invoke.attrs;
+		break;
+	}
+	case FASTRPC_LEGACY_IOCTL_INVOKE_CRC: {
+		struct fastrpc_legacy_invoke_crc invoke;
+
+		if (copy_from_user(&invoke, argp, sizeof(invoke)))
+			return -EFAULT;
+		inv = invoke.inv;
+		fds_ptr = invoke.fds;
+		attrs_ptr = invoke.attrs;
+		break;
+	}
+	default:
+		return -ENOTTY;
+	}
+
+	nscalars = REMOTE_SCALARS_LENGTH(inv.sc);
+	if (!nscalars)
+		return fastrpc_internal_invoke(fl, false, inv.handle,
+					      inv.sc, NULL);
+
+	legacy_args = memdup_user(u64_to_user_ptr(inv.args),
+				  array_size(nscalars, sizeof(*legacy_args)));
+	if (IS_ERR(legacy_args))
+		return PTR_ERR(legacy_args);
+
+	args = kcalloc(nscalars, sizeof(*args), GFP_KERNEL);
+	if (!args) {
+		err = -ENOMEM;
+		goto out;
+	}
+
+	if (fds_ptr) {
+		fds = memdup_user(u64_to_user_ptr(fds_ptr),
+				  array_size(nscalars, sizeof(*fds)));
+		if (IS_ERR(fds)) {
+			err = PTR_ERR(fds);
+			fds = NULL;
+			goto out;
+		}
+	}
+
+	if (attrs_ptr) {
+		attrs = memdup_user(u64_to_user_ptr(attrs_ptr),
+				    array_size(nscalars, sizeof(*attrs)));
+		if (IS_ERR(attrs)) {
+			err = PTR_ERR(attrs);
+			attrs = NULL;
+			goto out;
+		}
+	}
+
+	nbufs = REMOTE_SCALARS_INBUFS(inv.sc) +
+		REMOTE_SCALARS_OUTBUFS(inv.sc);
+	for (i = 0; i < nscalars; i++) {
+		if (i < nbufs) {
+			args[i].ptr = legacy_args[i].buf.ptr;
+			args[i].length = legacy_args[i].buf.length;
+			args[i].fd = fds ? fds[i] : -1;
+		} else {
+			args[i].ptr = legacy_args[i].dma.offset;
+			args[i].length = legacy_args[i].dma.length;
+			args[i].fd = fds ? fds[i] :
+				legacy_args[i].dma.fd;
+		}
+		args[i].attr = attrs ? attrs[i] : 0;
+	}
+
+	err = fastrpc_internal_invoke(fl, false, inv.handle, inv.sc, args);
+
+out:
+	kfree(attrs);
+	kfree(fds);
+	kfree(args);
+	kfree(legacy_args);
+
+	return err;
+}
+
+static int fastrpc_legacy_init(struct fastrpc_user *fl, char __user *argp)
+{
+	struct fastrpc_legacy_init init;
+	u32 pd_type;
+	int pd;
+	int err;
+
+	if (copy_from_user(&init, argp, sizeof(init)))
+		return -EFAULT;
+
+	switch (init.flags) {
+	case FASTRPC_LEGACY_INIT_ATTACH:
+		pd_type = FASTRPC_PD_TYPE_ROOT;
+		pd = ROOT_PD;
+		break;
+	case FASTRPC_LEGACY_INIT_ATTACH_SENSORS:
+		pd_type = FASTRPC_PD_TYPE_SENSORS;
+		pd = SENSORS_PD;
+		break;
+	default:
+		return -EOPNOTSUPP;
+	}
+
+	err = fastrpc_session_select(fl, pd_type);
+	if (err)
+		return err;
+
+	return fastrpc_init_attach(fl, pd);
+}
+
+static long fastrpc_legacy_device_ioctl(struct fastrpc_user *fl,
+					unsigned int cmd, char __user *argp)
+{
+	u32 info;
+	int err;
+
+	switch (cmd) {
+	case FASTRPC_LEGACY_IOCTL_GETINFO:
+		if (copy_from_user(&info, argp, sizeof(info)))
+			return -EFAULT;
+		if (info != ADSP_DOMAIN_ID)
+			return -EINVAL;
+		info = 1;
