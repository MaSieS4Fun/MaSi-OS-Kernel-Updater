From 3c5a821343c8f7c53ac5a9b9e4ec19f272d1328e Mon Sep 17 00:00:00 2001
From: suckbluefrog <suckbluefrog@proton.me>
Date: Thu, 16 Jul 2026 00:00:00 +0000
Subject: [PATCH] hexagonrpcd: add sns_registry reverse interface

Newer Qualcomm SensorsPD firmware opens a small reverse FastRPC interface
named sns_registry to query Android properties while processing
sns_reg_config. Linux has no Android property service, so return the empty
default value expected from property_get() when a property is unset.

Also expose sns_reg_version at its real Android path. It lives beside the
registry directory rather than inside it, so the existing HexagonFS mapping
could not serve it and SensorsPD attempted to recreate the registry.
---
 hexagonrpcd/interfaces.c                   |  1 +
 hexagonrpcd/interfaces/sns_registry.def    | 29 ++++++++++
 hexagonrpcd/meson.build                    |  1 +
 hexagonrpcd/rpcd.c                         |  5 +-
 hexagonrpcd/rpcd_builder.c                 | 14 ++++-
 hexagonrpcd/sns_registry.c                 | 83 +++++++++++++++++++++++
 hexagonrpcd/sns_registry.h                 | 32 +++++++++
 7 files changed, 163 insertions(+), 4 deletions(-)
 create mode 100644 hexagonrpcd/interfaces/sns_registry.def
 create mode 100644 hexagonrpcd/sns_registry.c
 create mode 100644 hexagonrpcd/sns_registry.h

diff --git a/hexagonrpcd/interfaces.c b/hexagonrpcd/interfaces.c
index 320b1a0..84f450b 100644
--- a/hexagonrpcd/interfaces.c
+++ b/hexagonrpcd/interfaces.c
@@ -23,3 +23,4 @@
 #include "interfaces/apps_mem.def"
 #include "interfaces/apps_std.def"
 #include "interfaces/adsp_listener.def"
+#include "interfaces/sns_registry.def"
diff --git a/hexagonrpcd/interfaces/sns_registry.def b/hexagonrpcd/interfaces/sns_registry.def
new file mode 100644
index 0000000..43821b7
--- /dev/null
+++ b/hexagonrpcd/interfaces/sns_registry.def
@@ -0,0 +1,29 @@
