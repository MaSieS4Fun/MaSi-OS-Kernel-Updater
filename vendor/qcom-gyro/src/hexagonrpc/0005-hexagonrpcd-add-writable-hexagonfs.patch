From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: suckbluefrog <suckbluefrog@proton.me>
Date: Thu, 16 Jul 2026 16:00:00 +0000
Subject: [PATCH] hexagonrpcd: add writable mapped-file operations

SensorsPD updates its persistent registry through the apps_std reverse
interface. Extend HexagonFS with flag-aware opens, writes, and truncation
while keeping virtual mappings read-only unless their backend explicitly
implements the writable operations.
---
 hexagonrpcd/hexagonfs.c          | 52 +++++++++++++++++++++++++++++---
 hexagonrpcd/hexagonfs.h          | 18 +++++++++++
 hexagonrpcd/hexagonfs_mapped.c   | 64 +++++++++++++++++++++++++++++++++++++---
 hexagonrpcd/hexagonfs_virt_dir.c | 29 ++++++++++++++++--
 4 files changed, 154 insertions(+), 9 deletions(-)

--- a/hexagonrpcd/hexagonfs.h
+++ b/hexagonrpcd/hexagonfs.h
@@ -34,12 +34,25 @@
 struct hexagonfs_file_ops {
 	void (*close)(void *fd_data);
 	int (*from_dirent)(const void *dirent_data, bool dir, void **fd_data);
+	int (*from_dirent_flags)(const void *dirent_data,
+				 bool dir,
+				 int flags,
+				 mode_t mode,
+				 void **fd_data);
 	int (*openat)(struct hexagonfs_fd *dir,
 		      const char *segment,
 		      bool expect_dir,
 		      struct hexagonfs_fd **out);
+	int (*openat_flags)(struct hexagonfs_fd *dir,
+			    const char *segment,
+			    bool expect_dir,
+			    int flags,
+			    mode_t mode,
+			    struct hexagonfs_fd **out);
 	int (*readdir)(struct hexagonfs_fd *fd, size_t size, char *out);
 	ssize_t (*read)(struct hexagonfs_fd *fd, size_t size, void *ptr);
+	ssize_t (*write)(struct hexagonfs_fd *fd, size_t size, const void *ptr);
+	int (*truncate)(struct hexagonfs_fd *fd, off_t length);
 	int (*stat)(struct hexagonfs_fd *fd, struct stat *stats);
 	int (*seek)(struct hexagonfs_fd *fd, off_t off, int whence);
 };
@@ -71,11 +84,16 @@
 
 int hexagonfs_open_root(struct hexagonfs_fd **fds, struct hexagonfs_dirent *root);
 int hexagonfs_openat(struct hexagonfs_fd **fds, int rootfd, int dirfd, const char *name);
+int hexagonfs_openat_flags(struct hexagonfs_fd **fds, int rootfd, int dirfd,
+			   const char *name, int flags, mode_t mode);
 int hexagonfs_close(struct hexagonfs_fd **fds, int fileno);
 
 int hexagonfs_fstat(struct hexagonfs_fd **fds, int fileno, struct stat *stats);
 int hexagonfs_lseek(struct hexagonfs_fd **fds, int fileno, off_t pos, int whence);
 int hexagonfs_readdir(struct hexagonfs_fd **fds, int fileno, size_t size, char *name);
 ssize_t hexagonfs_read(struct hexagonfs_fd **fds, int fileno, size_t size, void *ptr);
+ssize_t hexagonfs_write(struct hexagonfs_fd **fds, int fileno, size_t size,
+			const void *ptr);
+int hexagonfs_ftruncate(struct hexagonfs_fd **fds, int fileno, off_t length);
 
 #endif
--- a/hexagonrpcd/hexagonfs.c
+++ b/hexagonrpcd/hexagonfs.c
@@ -20,6 +20,7 @@
  */
 
 #include <errno.h>
+#include <fcntl.h>
 #include <stdbool.h>
 #include <stddef.h>
 #include <stdio.h>
@@ -139,12 +140,14 @@
 	return ret;
 }
 
-int hexagonfs_openat(struct hexagonfs_fd **fds, int rootfd, int dirfd, const char *name)
+int hexagonfs_openat_flags(struct hexagonfs_fd **fds, int rootfd, int dirfd,
+			   const char *name, int flags, mode_t mode)
 {
 	struct hexagonfs_fd *fd;
 	const char *curr = name;
 	char *segment;
 	bool expect_dir;
+	bool final_segment;
 	int selected = dirfd;
 	int ret = 0;
 
@@ -163,11 +166,17 @@
 			ret = -ENOMEM;
 			goto err;
 		}
+		final_segment = (*curr == '\0');
 
 		if (!strcmp(segment, ".")) {
 			goto next;
 		} else if (!strcmp(segment, "..")) {
 			fd = pop_dir(fd, fds[rootfd]);
+		} else if (final_segment && fd->ops->openat_flags != NULL) {
+			ret = fd->ops->openat_flags(fd, segment, expect_dir,
+						    flags, mode, &fd);
+		} else if (final_segment && flags != O_RDONLY) {
+			ret = -EROFS;
 		} else {
 			ret = fd->ops->openat(fd, segment, expect_dir, &fd);
 		}
@@ -191,6 +200,12 @@
 	return ret;
 }
 
+int hexagonfs_openat(struct hexagonfs_fd **fds, int rootfd, int dirfd,
+		     const char *name)
+{
+	return hexagonfs_openat_flags(fds, rootfd, dirfd, name, O_RDONLY, 0);
+}
+
 int hexagonfs_close(struct hexagonfs_fd **fds, int fileno)
 {
 	struct hexagonfs_fd *fd;
@@ -244,6 +259,41 @@
 	return fd->ops->read(fd, size, ptr);
 }
 
+ssize_t hexagonfs_write(struct hexagonfs_fd **fds, int fileno, size_t size,
+			const void *ptr)
+{
+	struct hexagonfs_fd *fd;
+
+	if (fileno < 0 || fileno >= HEXAGONFS_MAX_FD)
+		return -EBADF;
+
+	fd = fds[fileno];
+	if (fd == NULL)
+		return -EBADF;
+
+	if (fd->ops->write == NULL)
+		return -ENOSYS;
+
+	return fd->ops->write(fd, size, ptr);
+}
+
+int hexagonfs_ftruncate(struct hexagonfs_fd **fds, int fileno, off_t length)
+{
+	struct hexagonfs_fd *fd;
+
+	if (fileno < 0 || fileno >= HEXAGONFS_MAX_FD)
+		return -EBADF;
+
+	fd = fds[fileno];
+	if (fd == NULL)
+		return -EBADF;
+
+	if (fd->ops->truncate == NULL)
+		return -ENOSYS;
+
+	return fd->ops->truncate(fd, length);
+}
+
 int hexagonfs_readdir(struct hexagonfs_fd **fds, int fileno, size_t ent_size, char *ent)
 {
 	struct hexagonfs_fd *fd;
--- a/hexagonrpcd/hexagonfs_mapped.c
+++ b/hexagonrpcd/hexagonfs_mapped.c
@@ -35,6 +35,18 @@
 	DIR *dir;
 };
 
+static int mapped_from_dirent_flags(const void *dirent_data,
+				    bool dir,
+				    int flags,
+				    mode_t mode,
+				    void **fd_data);
+static int mapped_openat_flags(struct hexagonfs_fd *dir,
+			       const char *segment,
+			       bool expect_dir,
+			       int flags,
+			       mode_t mode,
+			       struct hexagonfs_fd **out);
+
 static void mapped_close(void *fd_data)
 {
 	struct mapped_ctx *ctx = fd_data;
@@ -49,9 +61,17 @@
 
 static int mapped_from_dirent(const void *dirent_data, bool dir, void **fd_data)
 {
+	return mapped_from_dirent_flags(dirent_data, dir, O_RDONLY, 0, fd_data);
+}
+
+static int mapped_from_dirent_flags(const void *dirent_data,
+				    bool dir,
+				    int flags,
+				    mode_t mode,
+				    void **fd_data)
+{
 	struct mapped_ctx *ctx;
 	const char *name = dirent_data;
-	int flags = O_RDONLY;
 	int ret;
 
 	ctx = malloc(sizeof(struct mapped_ctx));
@@ -61,7 +81,7 @@
 	if (dir)
 		flags |= O_DIRECTORY;
 
-	ctx->fd = open(name, flags);
+	ctx->fd = open(name, flags, mode);
 	if (ctx->fd == -1) {
 		ret = -errno;
 		goto err;
@@ -83,10 +103,19 @@
 			 bool expect_dir,
 			 struct hexagonfs_fd **out)
 {
+	return mapped_openat_flags(dir, segment, expect_dir, O_RDONLY, 0, out);
+}
+
+static int mapped_openat_flags(struct hexagonfs_fd *dir,
+			       const char *segment,
+			       bool expect_dir,
+			       int flags,
+			       mode_t mode,
+			       struct hexagonfs_fd **out)
+{
 	struct mapped_ctx *dir_ctx = dir->data;
 	struct hexagonfs_fd *fd;
 	struct mapped_ctx *ctx;
-	int flags = O_RDONLY;
 	int ret;
 
 	ctx = malloc(sizeof(struct mapped_ctx));
@@ -102,7 +131,7 @@
 	if (expect_dir)
 		flags |= O_DIRECTORY;
 
-	ctx->fd = openat(dir_ctx->fd, segment, flags);
+	ctx->fd = openat(dir_ctx->fd, segment, flags, mode);
 	if (ctx->fd == -1) {
 		ret = -errno;
 		goto err_free_fd;
@@ -138,6 +167,29 @@
 	return ret;
 }
 
+static ssize_t mapped_write(struct hexagonfs_fd *fd, size_t size,
+			    const void *in)
+{
+	struct mapped_ctx *ctx = fd->data;
+	ssize_t ret;
+
+	ret = write(ctx->fd, in, size);
+	if (ret < 0)
+		return -errno;
+
+	return ret;
+}
+
+static int mapped_truncate(struct hexagonfs_fd *fd, off_t length)
+{
+	struct mapped_ctx *ctx = fd->data;
+
+	if (ftruncate(ctx->fd, length))
+		return -errno;
+
+	return 0;
+}
+
 static int mapped_readdir(struct hexagonfs_fd *fd, size_t size, char *out)
 {
 	struct mapped_ctx *ctx = fd->data;
@@ -325,8 +377,12 @@
 struct hexagonfs_file_ops hexagonfs_mapped_ops = {
 	.close = mapped_close,
 	.from_dirent = mapped_from_dirent,
+	.from_dirent_flags = mapped_from_dirent_flags,
 	.openat = mapped_openat,
+	.openat_flags = mapped_openat_flags,
 	.read = mapped_read,
+	.write = mapped_write,
+	.truncate = mapped_truncate,
 	.readdir = mapped_readdir,
 	.seek = mapped_seek,
 	.stat = mapped_stat,
--- a/hexagonrpcd/hexagonfs_virt_dir.c
+++ b/hexagonrpcd/hexagonfs_virt_dir.c
@@ -20,6 +20,7 @@
  */
 
 #include <errno.h>
+#include <fcntl.h>
 #include <stdbool.h>
 #include <stdlib.h>
 #include <string.h>
@@ -27,6 +28,13 @@
 
 #include "hexagonfs.h"
 
+static int virt_dir_openat_flags(struct hexagonfs_fd *dir,
+				 const char *segment,
+				 bool expect_dir,
+				 int flags,
+				 mode_t mode,
+				 struct hexagonfs_fd **out);
+
 /*
  * This function searches for the relevant path segment in the path directory.
  * It is not optimized because it is dealing with small directories.
@@ -65,6 +73,17 @@
 			   bool expect_dir,
 			   struct hexagonfs_fd **out)
 {
+	return virt_dir_openat_flags(dir, segment, expect_dir,
+				      O_RDONLY, 0, out);
+}
+
+static int virt_dir_openat_flags(struct hexagonfs_fd *dir,
+				 const char *segment,
+				 bool expect_dir,
+				 int flags,
+				 mode_t mode,
+				 struct hexagonfs_fd **out)
+{
 	const struct hexagonfs_dirent *const **dirlist = dir->data;
 	const struct hexagonfs_dirent *ent;
 	struct hexagonfs_fd *fd;
@@ -82,7 +101,14 @@
 	fd->up = dir;
 	fd->ops = ent->ops;
 
-	ret = ent->ops->from_dirent(ent->u.ptr, expect_dir, &fd->data);
+	if (ent->ops->from_dirent_flags != NULL) {
+		ret = ent->ops->from_dirent_flags(ent->u.ptr, expect_dir,
+						  flags, mode, &fd->data);
+	} else if (flags == O_RDONLY) {
+		ret = ent->ops->from_dirent(ent->u.ptr, expect_dir, &fd->data);
+	} else {
+		ret = -EROFS;
+	}
 	if (ret)
 		goto err;
 
@@ -128,5 +154,6 @@
 	.close = virt_dir_close,
 	.from_dirent = virt_dir_from_dirent,
 	.openat = virt_dir_openat,
+	.openat_flags = virt_dir_openat_flags,
 	.stat = virt_dir_stat,
 };
-- 
2.50.1
