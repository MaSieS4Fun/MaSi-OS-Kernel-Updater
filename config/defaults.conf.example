# Copy to config/local.conf for local overrides only.
# The repo already ships config/defaults.conf with default values.

ROOT_UUID=""
# KERNEL_VER=""          # empty = auto (latest 7.0.x)
# KERNEL_SERIES="7.0"
# JOBS="$(nproc)"
# DEVICE_TARGET="all"    # odin2|portal|mini|thor
# GAMING_TUNING=1
# PATCH_POLICY=strict
# OUTPUT_SUFFIX=masi

INITRAMFS_PROFILE="gold"
DTB_STRATEGY="rocknix-chain-order"

# ROCKNIX_KERNEL="../Kernel-odin2/rocknix-boot-partition/KERNEL"
