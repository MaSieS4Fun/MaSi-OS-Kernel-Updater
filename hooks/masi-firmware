#!/bin/bash
# Minimal SM8550 firmware for early boot — never copy the full firmware/ tree.
[[ "$1" == "prereqs" ]] && exit 0
. /usr/share/initramfs-tools/hook-functions

FW_ROOT="/lib/firmware"
if [[ -f /etc/masi-firmware-staging ]]; then
    read -r staged < /etc/masi-firmware-staging
    [[ -n "${staged}" && -d "${staged}" ]] && FW_ROOT="${staged}"
fi

_add_path() {
    local rel="$1"
    local src="${FW_ROOT}/${rel}"
    if [[ -f "${src}" ]]; then
        mkdir -p "${DESTDIR}/lib/firmware/$(dirname "${rel}")"
        cp -L "${src}" "${DESTDIR}/lib/firmware/${rel}"
        return 0
    fi
    if [[ -d "${src}" ]]; then
        local f drel
        while IFS= read -r f; do
            drel="${f#${FW_ROOT}/}"
            mkdir -p "${DESTDIR}/lib/firmware/$(dirname "${drel}")"
            cp -L "${f}" "${DESTDIR}/lib/firmware/${drel}"
        done < <(find "${src}" -type f 2>/dev/null)
    fi
}

# Subconjunto alineado con EFI gold / ayn-firmware (~47–61 MB initrd total).
for rel in \
    qcom/sm8550 \
    qcom/a740_sqe.fw \
    qcom/gmu_gen70200.bin \
    qcom/vpu/vpu30_p4.mbn \
    ath12k/WCN7850/hw2.0 \
    qcom/sm8550/ayn; do
    _add_path "${rel}"
done

ayn="${DESTDIR}/lib/firmware/qcom/sm8550/ayn"
if [[ -d "${ayn}/odin2" ]]; then
    for dev in odin2mini odin2portal thor; do
        [[ -e "${ayn}/${dev}" ]] || ln -sfn odin2 "${ayn}/${dev}"
    done
fi
